{
  "name": "whatsapp-saas",
  "version": "1.0.0",
  "description": "Multi-tenant WhatsApp SaaS platform for bulk messaging, chat management, and WhatsApp device management",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon --delay 1500ms src/server.js",
    "worker": "node src/services/worker/MessageWorker.js",
    "seed": "node scripts/seedSubscriptionPlans.js",
    "lint": "eslint src/**/*.js",
    "test": "jest --coverage --forceExit",
    "test:watch": "jest --watch",
    "pm2:start": "pm2 start pm2.config.js",
    "pm2:stop": "pm2 stop all",
    "pm2:restart": "pm2 restart all",
    "pm2:logs": "pm2 logs"
  },
  "keywords": [
    "whatsapp",
    "saas",
    "messaging",
    "multi-tenant"
  ],
  "author": "WhatsApp SaaS Team",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.2",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "stripe": "^20.4.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "whatsapp-web.js": "^1.34.6",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "autoprefixer": "^10.4.24",
    "axios": "^1.13.5",
    "date-fns": "^4.1.0",
    "jest": "^30.2.0",
    "lucide-react": "^0.575.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.1",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.1"
  }
